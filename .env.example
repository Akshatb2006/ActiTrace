# Copy to .env and fill in values.
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_STRING

# Groq API key (https://console.groq.com). Optional — leave empty to disable
# the "Health insights" card on session reports.
GROQ_API_KEY=

# Comma-separated list of origins the backend accepts.
CORS_ORIGINS=http://localhost:3100
